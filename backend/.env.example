# VendorCompare Backend — Required Environment Variables
# Copy to .env (gitignored) and fill in values before running.

# REQUIRED in production. In dev, defaults to "dev-secret-change-in-prod" (unsafe).
# Rotate if this has ever been committed or shared. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database path. Defaults to ./vendorcompare.db (relative to backend/ dir).
# Electron app sets this automatically. Required for manual uvicorn starts.
DATABASE_URL=sqlite:///./vendorcompare.db

# Ollama model endpoint (LOM AI Edition only)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
VENDORCOMPARE_MODEL=qwen2.5:7b

# Inference tuning (optional — defaults shown)
TAQUITO_TEMPERATURE=0.1
TAQUITO_TOP_P=0.85
TAQUITO_TOP_K=30
TAQUITO_REPEAT_PENALTY=1.1

# Set to "production" to enforce SECRET_KEY must be non-default
VENDORCOMPARE_ENV=development
